        "# 1. Importiamo Plotly, il re dei grafici interattivi\n",
        "import plotly.express as px\n",
        "\n",
        "# 2. Creiamo il grafico a barre\n",
        "# 'x' sarà l'orientamento politico, 'y' sarà il punteggio.\n",
        "# Coloriamo le barre in base al punteggio per rendere subito chiaro chi è negativo e chi positivo\n",
        "grafico_sentiment = px.bar(\n",
        "    risultati_geopolitici,\n",
        "    x='Orientamento governo',\n",
        "    y='Sentiment_Score',\n",
        "    color='Sentiment_Score',\n",
        "    color_continuous_scale='RdBu', # Rosso per i negativi, Blu per i positivi\n",
        "    title='<b>Sentiment Geopolitico per Fazione</b> (Analisi RoBERTa)',\n",
        "    labels={'Orientamento governo': 'Fazione Geopolitica', 'Sentiment_Score': 'Punteggio Medio'},\n",
        "    text_auto='.2f' # Mostra il numero sulla barra arrotondato a due decimali\n",
        ")\n",
        "\n",
        "# 3. Rendiamo il grafico ancora più bello e \"pulito\"\n",
        "grafico_sentiment.update_layout(\n",
        "    xaxis_title='', # Nascondiamo l'etichetta dell'asse X perché è già ovvia\n",
        "    yaxis_title='Positività / Negatività',\n",
        "    plot_bgcolor='rgba(0,0,0,0)', # Sfondo trasparente, molto elegante\n",
        "    title_x=0.5 # Centriamo il titolo\n",
        ")\n",
        "\n",
        "# 4. Mostriamo il capolavoro\n",
        "grafico_sentiment.show()"
