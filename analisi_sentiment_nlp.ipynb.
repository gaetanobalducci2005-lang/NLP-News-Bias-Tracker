        "# 1. SETUP: Installazioni (silenziose) e Import\n",
        "!pip install -q transformers torch pandas\n",
        "import pandas as pd\n",
        "import torch\n",
        "from transformers import pipeline\n",
        "\n",
        "# 2. DATI: Caricamento e Pulizia preventiva\n",
        "data_url = \"https://raw.githubusercontent.com/gaetanobalducci2005-lang/NLP-News-Bias-Tracker/main/NLP_Dataset(Foglio1).csv\"\n",
        "# Leggiamo il CSV gestendo separatore, codifica e linee malformate; puliamo subito i titoli vuoti\n",
        "dataset = pd.read_csv(data_url, sep=';', encoding='latin1', on_bad_lines='skip').fillna({'Titolo': 'No text'})\n",
        "\n",
        "# 3. MODELLO: Setup IA con accelerazione GPU (device=0) se disponibile\n",
        "device = 0 if torch.cuda.is_available() else -1\n",
        "print(f\"🤖 Setup modello RoBERTa in corso su dispositivo: {'GPU' if device==0 else 'CPU'}...\")\n",
        "analizzatore = pipeline(\"sentiment-analysis\", model=\"cardiffnlp/twitter-roberta-base-sentiment-latest\", truncation=True, max_length=512, device=device)\n",
        "\n",
        "# 4. ESECUZIONE: Analisi in BATCH (molto più veloce con la GPU)\n",
        "print(\"🧠 Analisi geopolitica parallela sui titoli...\")\n",
        "# Estraiamo 'label' direttamente in lista per efficienza\n",
        "dataset['RoBERTa_Sentiment'] = [res['label'] for res in analizzatore(dataset['Titolo'].astype(str).tolist())]\n",
        "\n",
        "# --- RISULTATO INTERMEDIO ---\n",
        "print(\"✅ Analisi completata. Ecco le prime 10 righe con i sentimenti:\")\n",
        "# Usa display() per forzare la visualizzazione anche se non è l'ultima riga\n",
        "display(dataset.head(10))\n"
      ],
