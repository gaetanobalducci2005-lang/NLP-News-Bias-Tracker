# 1. SETUP: Installazioni (silenziose) e Import
!pip install -q transformers torch pandas
import pandas as pd
import torch
from transformers import pipeline

# 2. DATI: Caricamento e Pulizia preventiva
data_url = "https://raw.githubusercontent.com/gaetanobalducci2005-lang/NLP-News-Bias-Tracker/main/NLP_Dataset(Foglio1).csv"
# Leggiamo il CSV gestendo separatore, codifica e linee malformate; puliamo subito i titoli vuoti
dataset = pd.read_csv(data_url, sep=';', encoding='latin1', on_bad_lines='skip').fillna({'Titolo': 'No text'})

# 3. MODELLO: Setup IA con accelerazione GPU (device=0) se disponibile
device = 0 if torch.cuda.is_available() else -1
print(f"🤖 Setup modello RoBERTa in corso su dispositivo: {'GPU' if device==0 else 'CPU'}...")
analizzatore = pipeline("sentiment-analysis", model="cardiffnlp/twitter-roberta-base-sentiment-latest", truncation=True, max_length=512, device=device)

# 4. ESECUZIONE: Analisi in BATCH (molto più veloce con la GPU)
print("🧠 Analisi geopolitica parallela sui titoli...")
# Estraiamo 'label' direttamente in lista per efficienza
dataset['RoBERTa_Sentiment'] = [res['label'] for res in analizzatore(dataset['Titolo'].astype(str).tolist())]

# --- RISULTATO INTERMEDIO ---
print("✅ Analisi completata. Ecco le prime 10 righe con i sentimenti:")
# Usa display() per forzare la visualizzazione anche se non è l'ultima riga
display(dataset.head(10))




# 5. AGGREGAZIONE: Mappatura numerica e raggruppamento
# In un solo blocco logico (method chaining), mappiamo, raggruppiamo, calcoliamo media e ordiniamo.
# positive:1, neutral:0, negative:-1
risultati_geopolitici = (
    dataset.assign(Sentiment_Score=dataset['RoBERTa_Sentiment'].map({'positive': 1, 'neutral': 0, 'negative': -1}))
        .groupby('Orientamento governo')['Sentiment_Score']
            .mean()
                .reset_index()
                    .sort_values(by='Sentiment_Score', ascending=False)
                    )

# --- RISULTATO FINALE ---
print("📊 Medie del sentiment RoBERTa per fazione geopolitica:")
display(risultati_geopolitici)






# 1. Importiamo Plotly, il re dei grafici interattivi
import plotly.express as px

# 2. Creiamo il grafico a barre
# 'x' sarà l'orientamento politico, 'y' sarà il punteggio.
# Coloriamo le barre in base al punteggio per rendere subito chiaro chi è negativo e chi positivo
grafico_sentiment = px.bar(
    risultati_geopolitici,
    x='Orientamento governo',
    y='Sentiment_Score',
    color='Sentiment_Score',
    color_continuous_scale='RdBu', # Rosso per i negativi, Blu per i positivi
    title='<b>Sentiment Geopolitico per Fazione</b> (Analisi RoBERTa)',
    labels={'Orientamento governo': 'Fazione Geopolitica', 'Sentiment_Score': 'Punteggio Medio'},
    text_auto='.2f' # Mostra il numero sulla barra arrotondato a due decimali
)

# 3. Rendiamo il grafico ancora più bello e "pulito"
grafico_sentiment.update_layout(
    xaxis_title='', # Nascondiamo l'etichetta dell'asse X perché è già ovvia
    yaxis_title='Positività / Negatività',
    plot_bgcolor='rgba(0,0,0,0)', # Sfondo trasparente, molto elegante
    title_x=0.5 # Centriamo il titolo
)

# 4. Mostriamo il capolavoro
grafico_sentiment.show()
